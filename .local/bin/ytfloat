#!/bin/bash
# Usage: ytfloat <youtube-url>
url="$1"

# Extract list ID if present, rebuild as a proper playlist URL
if [[ "$url" == *"list="* ]]; then
  list_id=$(echo "$url" | grep -oP 'list=\K[^&]+')
  url="https://www.youtube.com/playlist?list=$list_id"
fi

mpv --hwdec=auto --ytdl-format="best[height<=720]" "$url"
